# Default real HAL bring-up mode
DATA_SOURCE=real

# Modem control GPIOs from the project research notes
GPIO_MODEM_POWER_NUMBER=24
GPIO_MODEM_RESET_NUMBER=15

# Fill this in once the dock-detect GPIO is assigned on your carrier
# GPIO_DOCK_DETECT_NUMBER=23
# GPIO_DOCK_DETECT_ACTIVE_LOW=1

# Optional dock behavior during early bring-up
# DOCK_INFER_FROM_ETHERNET=1
# DOCK_POWER_BUDGET_W=15

# Optional probe timing trace for real HAL debugging
# REAL_HAL_TRACE=1

# Optional display overrides during bring-up
# DISPLAY_WIDTH=1280
# DISPLAY_HEIGHT=720
# DISPLAY_SCALE=1
# DISPLAY_MODE=handheld

# Optional keyboard overrides during bring-up
# KEYBOARD_NAME_HINT=uconsole
# KEYBOARD_LAYOUT=uconsole
# KEYBOARD_CONNECTED=1
# KEYBOARD_INPUT_MODE=keyboard
